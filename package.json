{
  "name": "experiment",
  "homepage": ".",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1003.0",
    "@aws-sdk/lib-dynamodb": "^3.1003.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.8.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vendia/serverless-express": "^4.12.6",
    "aws-cdk-lib": "2.220.0",
    "bootstrap": "^5.3.8",
    "canvas": "^3.2.2",
    "constructs": "^10.4.2",
    "dom-to-image": "^2.6.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "genetic-search": "^13.5.0",
    "puppeteer": "^24.40.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.5",
    "uuid": "^13.0.0",
    "wait-on": "^9.0.4",
    "web-vitals": "^5.1.0",
    "zod": "^4.1.12"
  },
  "scripts": {
    "build-lambda": "node scripts/build-lambda.mjs",
    "local-aws-sam-deploy": "npm run build-app && cdk synth && sam local start-api -t ./cdk.out/gateway.template.json --port 3003 --env-vars env.json",
    "build-pages": "node scripts/generate-page-index.mjs",
    "bootstrap": "cdk bootstrap --profile ted --force",
    "deploy-cdk": "cdk deploy --profile ted",
    "deploy-force": "cdk deploy --profile ted --force",
    "deploy-cdk-full": "npm run build-app && npm run deploy-cdk",
    "test": "jest",
    "eject": "react-scripts eject",
    "test-cdk": "jest",
    "cdk": "cdk",
    "serve": "npx serve -s build",
    "build-server": "tsc -p tsconfig.json && tsc -p tsconfig.server.json",
    "build-app": "npm run build && npm run build-server",
    "start-app1": "npm run build-app && npm run serve",
    "start-app": "npm run build-app && npm run dev",
    "start-server": "ts-node-dev --respawn --transpile-only src/server/index.ts",
    "dev": "concurrently \"npm run dev-login\" \"npm run dev-student\" \"npm run dev-teacher\"",
    "dev-login": "vite --config vite.config.login.ts --open index-login.html",
    "dev-student": "vite --config vite.config.student.ts --open index-student.html",
    "dev-teacher": "vite --config vite.config.teacher.ts --open index-teacher.html",
    "build": "vite build --config vite.config.student.ts && vite build --config vite.config.teacher.ts && vite build --config vite.config.login.ts",
    "preview": "vite preview",
    "lint": "eslint .",
    "generate-images": "npm start  scripts/images/my-react-app/src/generate-images.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/preset-react": "^7.28.5",
    "@types/aws-lambda": "^8.10.157",
    "@types/bootstrap": "^5.2.10",
    "@types/jest": "^30.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "aws-cdk": "2.1030.0",
    "concurrently": "^9.2.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.2"
  }
}
